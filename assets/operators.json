{
  "operators": [
    {
      "node_name": "Control::GateExecution",
      "executable": "patch",
      "static_args": ["-p1", "--batch"],
      "input_mapping": {
        "stdin_source": "diff"
      }
    },
    {
      "node_name": "State::Validate",
      "executable": "cargo",
      "static_args": ["test", "--release"],
      "input_mapping": {
        "stdin_source": null
      }
    },
    {
      "node_name": "State::Plan",
      "executable": "python3",
      "static_args": ["assets/call_llm.py", "--template", "plan"],
      "input_mapping": {
        "stdin_mode": "json"
      },
      "output_mode": "tensor_plan"
    },
    {
      "node_name": "State::Memory",
      "executable": "python3",
      "static_args": ["assets/memory.py"],
      "input_mapping": {
        "stdin_mode": "json"
      }
    },
    {
      "node_name": "Control::Repair",
      "executable": "python3",
      "static_args": ["assets/call_llm.py", "--template", "repair"],
      "input_mapping": {
        "stdin_mode": "json"
      },
      "output_mode": "tensor_plan"
    }
  ]
}