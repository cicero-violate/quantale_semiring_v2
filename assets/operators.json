    {
      "node_name": "Execution::DynamicAlphaSignalEvaluator",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = tanhf(in0[i]) * in2[i] * (1.0f - fabsf(in1[i]));",
      "effects": {
        "reads": [
          "market.feed",
          "portfolio.state",
          "trading.signals"
        ],
        "writes": [
          "execution.gpu.results"
        ],
        "locks": []
      }
    },
    {
      "node_name": "Execution::OrderBookImbalanceWeaver",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = in2[i] * (1.0f + 0.5f * tanhf(in0[i]));",
      "effects": {
        "reads": [
          "market.feed",
          "portfolio.state",
          "trading.signals"
        ],
        "writes": [
          "execution.gpu.results"
        ],
        "locks": []
      }
    },
    {
      "node_name": "Execution::PortfolioRiskConstraintFilter",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = fmaxf(-1.0f, fminf(1.0f, in2[i] * (1.0f - fabsf(in1[i]))));",
      "effects": {
        "reads": [
          "market.feed",
          "portfolio.state",
          "trading.signals"
        ],
        "writes": [
          "execution.gpu.results"
        ],
        "locks": []
      }
    },
    {
      "node_name": "Execution::AdaptiveOptionsPricingArray",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = expf(-fabsf(in1[i])) * fmaxf(0.0f, in0[i] + in2[i]);",
      "effects": {
        "reads": [
          "market.feed",
          "portfolio.state",
          "trading.signals"
        ],
        "writes": [
          "execution.gpu.results"
        ],
        "locks": []
      }
    },
    {
      "node_name": "Execution::HardwareTailoredFeedHandler",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = tanhf(in0[i]) + 0.01f * in1[i] + 0.01f * in2[i];",
      "effects": {
        "reads": [
          "market.feed",
          "portfolio.state",
          "trading.signals"
        ],
        "writes": [
          "execution.gpu.results"
        ],
        "locks": []
      }
    },
    {
      "node_name": "Execution::VectorAdd",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = in0[i] + in1[i];",
      "effects": {
        "reads": [
          "math.a",
          "math.b"
        ],
        "writes": [
          "math.add_out"
        ],
        "locks": []
      }
    },
    {
      "node_name": "Execution::VectorScale",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = in0[i] * in1[i];",
      "effects": {
        "reads": [
          "math.add_out",
          "math.scale"
        ],
        "writes": [
          "math.out"
        ],
        "locks": []
      }
    },
    {
      "node_name": "Execution::FusedVectorAddScale",
      "executable": "jit_cuda",
      "static_args": [],
      "jit_body": "out[i] = (in0[i] + in1[i]) * in2[i];",
      "effects": {
        "reads": [
          "math.a",
          "math.b",
          "math.scale"
        ],
        "writes": [
          "math.out"
        ],
        "locks": []
      }
    },
