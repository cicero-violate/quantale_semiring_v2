      "confidence": 0.72,
      "cost": 1.0,
      "safety": 0.86
    },
    {
      "name": "market_analysis_loop_seq",
      "expr": {
        "seq": [
          "State::Input",
          "State::MarketFeed",
          "Event::MarketFeedUpdated",
          "State::AnalysisPlan",
