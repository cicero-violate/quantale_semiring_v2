{
  "matrix_name": "quantale_semiring_v2",
  "version": 1,

  "slots": {
    "env.task":                     { "type": "json",   "kind": "input"   },
    "task.context":                 { "type": "json",   "kind": "state"   },
    "market.config":                { "type": "json",   "kind": "config"  },
    "market.feed":                  { "type": "json",   "kind": "state"   },
    "market.price":                 { "type": "f32[]",  "kind": "tensor"  },
    "market.open":                  { "type": "f32[]",  "kind": "tensor"  },
    "analysis.config":              { "type": "json",   "kind": "config"  },
    "analysis.plan":                { "type": "json",   "kind": "state"   },
    "analysis.return":              { "type": "f32[]",  "kind": "tensor"  },
    "analysis.volatility":          { "type": "f32[]",  "kind": "tensor"  },
    "analysis.signal_score":        { "type": "f32[]",  "kind": "tensor"  },
    "trade.decision":               { "type": "json",   "kind": "state"   },
    "trading.policy":               { "type": "json",   "kind": "config"  },
    "trade.receipt":                { "type": "json",   "kind": "receipt" },
    "plan.tensor":                  { "type": "json",   "kind": "state"   },
    "optimized.tensor":             { "type": "json",   "kind": "state"   },
    "execution.report":             { "type": "json",   "kind": "state"   },
    "validation.report":            { "type": "json",   "kind": "state"   },
    "commit.record":                { "type": "json",   "kind": "state"   },
    "memory.store":                 { "type": "json",   "kind": "state"   },
    "learning.tensor":              { "type": "json",   "kind": "state"   },
    "repair.intent":                { "type": "json",   "kind": "state"   },
    "retry.intent":                 { "type": "json",   "kind": "state"   },
    "map.candidates":               { "type": "json",   "kind": "state"   },
    "search.results":               { "type": "json",   "kind": "state"   },
    "parse.tree":                   { "type": "json",   "kind": "state"   },
    "score.report":                 { "type": "json",   "kind": "state"   },
    "workspace.diff":               { "type": "bytes",  "kind": "state"   },
    "workspace.files":              { "type": "bytes",  "kind": "state"   },
    "receipt.report":               { "type": "json",   "kind": "receipt" },
    "math.a":                       { "type": "f32[]",  "kind": "tensor"  },
    "math.b":                       { "type": "f32[]",  "kind": "tensor"  },
    "math.scale":                   { "type": "f32[]",  "kind": "tensor"  },
    "math.add_out":                 { "type": "f32[]",  "kind": "tensor"  },
    "math.out":                     { "type": "f32[]",  "kind": "tensor"  },
    "portfolio.state":              { "type": "json",   "kind": "state"   },
    "trading.signals":              { "type": "f32[]",  "kind": "tensor"  },
    "execution.gpu.results":        { "type": "f32[]",  "kind": "tensor"  },
    "state/quantale.tlog":          { "type": "jsonl",  "kind": "log"     },
    "state/learned_edges.jsonl":    { "type": "jsonl",  "kind": "log"     },
    "state/market_feed.jsonl":      { "type": "jsonl",  "kind": "log"     },
    "state/paper_orders.jsonl":     { "type": "jsonl",  "kind": "log"     },
    "state/paper_positions.json":   { "type": "json",   "kind": "state"   },
    "state/topology_mutations.jsonl":{ "type": "jsonl", "kind": "log"     },
    "state/mutation_queue.jsonl":   { "type": "jsonl",  "kind": "log"     },
    "introspect.report":            { "type": "json",   "kind": "state"   },
    "topology.plan":                { "type": "json",   "kind": "state"   },
    "operator.plan":                { "type": "json",   "kind": "state"   },
    "pattern.plan":                 { "type": "json",   "kind": "state"   },
    "select.result":                { "type": "json",   "kind": "state"   },
    "mutation.review":              { "type": "json",   "kind": "state"   },
    "rollback.record":              { "type": "json",   "kind": "state"   }
  },

  "resources": {
    "cuda":           { "kind": "gpu",  "capacity": 1 },
    "workspace":      { "kind": "lock", "capacity": 1 },
    "memory":         { "kind": "lock", "capacity": 1 },
    "executor":       { "kind": "lock", "capacity": 1 },
    "commit":         { "kind": "lock", "capacity": 1 },
    "learning":       { "kind": "lock", "capacity": 1 },
    "topology":       { "kind": "lock", "capacity": 1 },
    "topology_assets":{ "kind": "lock", "capacity": 1 },
    "paper_broker":   { "kind": "lock", "capacity": 1 },
    "operators_lib":  { "kind": "lock", "capacity": 1 },
    "patterns":       { "kind": "lock", "capacity": 1 }
  },

  "quantale": {
    "layers": [
      { "name": "confidence", "join": "max", "compose": "times", "bottom": 0.0,   "unit": 1.0 },
      { "name": "cost",       "join": "min", "compose": "plus",  "bottom": "inf", "unit": 0.0 },
      { "name": "safety",     "join": "max", "compose": "min",   "bottom": 0.0,   "unit": 1.0 }
    ]
  },

  "nodes": [
    {
      "name": "Analysis::Return1",
      "kind": "kernel",
      "runtime": { "backend": "cuda", "module": "analysis", "kernel": "analysis_return1" },
      "reads": ["market.price", "market.open"],
      "writes": ["analysis.return"],
      "locks": []
    },
    {
      "name": "Analysis::Volatility",
      "kind": "kernel",
      "runtime": { "backend": "cuda", "module": "analysis", "kernel": "analysis_volatility" },
      "reads": ["market.price", "analysis.return"],
      "writes": ["analysis.volatility"],
      "locks": []
    },
    {
      "name": "Analysis::SignalScore",
      "kind": "kernel",
      "runtime": { "backend": "cuda", "module": "analysis", "kernel": "analysis_signal_score" },
      "reads": ["analysis.return", "analysis.volatility"],
      "writes": ["analysis.signal_score"],
      "locks": []
    },
    {
      "name": "Execution::VectorAdd",
      "kind": "kernel",
      "runtime": { "backend": "cuda", "module": "math", "kernel": "vector_add" },
      "reads": ["math.a", "math.b"],
      "writes": ["math.add_out"],
      "locks": []
    },
    {
      "name": "Execution::VectorScale",
      "kind": "kernel",
      "runtime": { "backend": "cuda", "module": "math", "kernel": "vector_scale" },
      "reads": ["math.add_out", "math.scale"],
      "writes": ["math.out"],
      "locks": []
    },
    {
      "name": "Execution::FusedVectorAddScale",
      "kind": "kernel",
      "runtime": { "backend": "cuda", "module": "math", "kernel": "fused_vector_add_scale" },
      "reads": ["math.a", "math.b", "math.scale"],
      "writes": ["math.out"],
      "locks": []
    },
    {
      "name": "State::Input",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "python", "script": "crates/operators_lib/input.py" },
      "reads": ["env.task"],
      "writes": ["task.context"],
      "locks": []
    },
    {
      "name": "State::MarketFeed",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/market_feed.py" },
      "reads": ["market.config"],
      "writes": ["market.feed", "state/market_feed.jsonl"],
      "locks": [],
      "governance": { "network": true, "allowed_hosts": ["coingecko", "stooq"] }
    },
    {
      "name": "State::AnalysisPlan",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/call_llm.py", "template": "analysis" },
      "reads": ["market.feed", "analysis.config"],
      "writes": ["analysis.plan"],
      "locks": [],
      "governance": { "llm": true }
    },
    {
      "name": "State::TradePlan",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/call_llm.py", "template": "trade" },
      "reads": ["market.feed", "trading.policy"],
      "writes": ["trade.decision"],
      "locks": [],
      "governance": { "llm": true }
    },
    {
      "name": "State::PaperTrade",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/paper_trade.py" },
      "reads": ["trade.decision", "market.feed", "trading.policy"],
      "writes": ["trade.receipt", "state/paper_orders.jsonl", "state/paper_positions.json"],
      "locks": ["paper_broker"],
      "governance": { "trading": true }
    },
    {
      "name": "State::Plan",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/call_llm.py", "template": "plan" },
      "reads": ["task.context"],
      "writes": ["plan.tensor"],
      "locks": [],
      "governance": { "llm": true }
    },
    {
      "name": "State::Optimize",
      "kind": "host_node",
      "purity": "pure",
      "runtime": { "backend": "noop" },
      "reads": ["plan.tensor"],
      "writes": ["optimized.tensor"],
      "locks": []
    },
    {
      "name": "State::Execute",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "noop" },
      "reads": ["optimized.tensor"],
      "writes": ["execution.report"],
      "locks": ["executor"]
    },
    {
      "name": "State::Memory",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "python", "script": "crates/operators_lib/memory.py" },
      "reads": ["task.context"],
      "writes": ["memory.store"],
      "locks": ["memory"]
    },
    {
      "name": "State::Learn",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "python", "script": "crates/operators_lib/learn.py" },
      "reads": ["memory.store", "state/quantale.tlog"],
      "writes": ["learning.tensor", "state/learned_edges.jsonl"],
      "locks": ["learning"]
    },
    {
      "name": "Control::GateExecution",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "patch" },
      "reads": ["workspace.diff"],
      "writes": ["workspace.files"],
      "locks": ["workspace"]
    },
    {
      "name": "State::Validate",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "cargo", "args": ["test", "--release"] },
      "reads": ["workspace.files"],
      "writes": ["validation.report"],
      "locks": []
    },
    {
      "name": "Control::Commit",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/commit.py" },
      "reads": ["task.context", "execution.report", "validation.report"],
      "writes": ["commit.record"],
      "locks": ["commit"],
      "governance": { "git": true }
    },

    { "name": "Event::AnalysisFinished",     "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::AnalysisPlanReady",    "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::CandidateFound",       "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ExecuteFinished",      "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ExecuteStarted",       "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::FactArrived",          "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::HashNonzero",          "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::InputAccepted",        "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::LearnUpdated",         "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::MapReady",             "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::MarketFeedUpdated",    "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::MemoryWritten",        "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::MutationReviewed",     "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::OperatorWritten",      "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::OptimizeReady",        "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::PaperTradeFilled",     "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::PaperTradeRejected",   "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ParseErr",             "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ParseOk",              "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::PatternMutated",       "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::PlanReady",            "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ReceiptAccepted",      "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ReceiptAttached",      "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ReceiptRejected",      "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::ScoreReady",           "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::TopKSelected",         "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::TopologyMutated",      "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::TopologyOverlayBuilt", "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },
    { "name": "Event::TradeDecisionReady",   "kind": "event_node", "runtime": { "backend": "noop" }, "reads": [], "writes": [], "locks": [] },

    {
      "name": "State::Goal",
      "kind": "host_node",
      "purity": "pure",
      "runtime": { "backend": "noop" },
      "reads": ["env.task"],
      "writes": ["task.context"],
      "locks": []
    },
    {
      "name": "State::Introspect",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/call_llm.py", "template": "introspect" },
      "reads": ["state/quantale.tlog", "state/learned_edges.jsonl", "state/topology_mutations.jsonl"],
      "writes": ["introspect.report"],
      "locks": [],
      "governance": { "llm": true }
    },
    {
      "name": "State::Map",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "python", "script": "crates/operators_lib/map.py" },
      "reads": ["task.context"],
      "writes": ["map.candidates"],
      "locks": []
    },
    {
      "name": "State::MutationReview",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/mutation_review.py" },
      "reads": ["state/mutation_queue.jsonl"],
      "writes": ["mutation.review"],
      "locks": [],
      "governance": { "review": true }
    },
    {
      "name": "State::OperatorPlan",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/call_llm.py", "template": "operator_plan" },
      "reads": ["state/topology_mutations.jsonl"],
      "writes": ["operator.plan"],
      "locks": [],
      "governance": { "llm": true }
    },
    {
      "name": "State::Parse",
      "kind": "host_node",
      "purity": "pure",
      "runtime": { "backend": "python", "script": "crates/operators_lib/parse.py" },
      "reads": ["task.context"],
      "writes": ["parse.tree"],
      "locks": []
    },
    {
      "name": "State::PatternPlan",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/call_llm.py", "template": "pattern_plan" },
      "reads": ["state/quantale.tlog"],
      "writes": ["pattern.plan"],
      "locks": [],
      "governance": { "llm": true }
    },
    {
      "name": "State::Score",
      "kind": "host_node",
      "purity": "pure",
      "runtime": { "backend": "python", "script": "crates/operators_lib/score.py" },
      "reads": ["parse.tree"],
      "writes": ["score.report"],
      "locks": []
    },
    {
      "name": "State::Search",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "python", "script": "crates/operators_lib/search.py" },
      "reads": ["map.candidates"],
      "writes": ["search.results"],
      "locks": []
    },
    {
      "name": "State::Select",
      "kind": "host_node",
      "purity": "pure",
      "runtime": { "backend": "python", "script": "crates/operators_lib/select.py" },
      "reads": ["score.report"],
      "writes": ["select.result"],
      "locks": []
    },
    {
      "name": "State::TopologyPlan",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/call_llm.py", "template": "topology_plan" },
      "reads": ["state/quantale.tlog", "state/topology_mutations.jsonl"],
      "writes": ["topology.plan"],
      "locks": [],
      "governance": { "llm": true }
    },

    {
      "name": "Control::Allow",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": [],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::Block",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": [],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::BuildTopologyOverlay",
      "kind": "host_node",
      "purity": "deterministic_io",
      "runtime": { "backend": "cargo", "args": ["run", "--", "topology", "build-overlay"] },
      "reads": [],
      "writes": [],
      "locks": ["topology_assets"]
    },
    {
      "name": "Control::ChooseBest",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": ["plan.tensor"],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::GateInput",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": [],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::GateLearn",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": [],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::GateMemory",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": [],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::GateReceipt",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": [],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::Halt",
      "kind": "policy_node",
      "runtime": { "backend": "noop" },
      "reads": [],
      "writes": [],
      "locks": []
    },
    {
      "name": "Control::PatternMutate",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/pattern_mutate.py" },
      "reads": ["pattern.plan"],
      "writes": ["state/topology_mutations.jsonl"],
      "locks": ["patterns"],
      "governance": { "self_modification": true }
    },
    {
      "name": "Control::Repair",
      "kind": "host_node",
      "purity": "pure",
      "runtime": { "backend": "noop" },
      "reads": ["receipt.report"],
      "writes": ["repair.intent"],
      "locks": []
    },
    {
      "name": "Control::Retry",
      "kind": "host_node",
      "purity": "pure",
      "runtime": { "backend": "noop" },
      "reads": ["receipt.report"],
      "writes": ["retry.intent"],
      "locks": []
    },
    {
      "name": "Control::Rollback",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/rollback.py" },
      "reads": ["commit.record"],
      "writes": ["rollback.record"],
      "locks": ["commit"],
      "governance": { "git": true }
    },
    {
      "name": "Control::TopologyMutate",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/topology_mutate.py" },
      "reads": ["topology.plan"],
      "writes": ["state/topology_mutations.jsonl"],
      "locks": ["topology"],
      "governance": { "self_modification": true }
    },
    {
      "name": "Control::WriteOperator",
      "kind": "boundary_node",
      "runtime": { "backend": "python", "script": "crates/operators_lib/write_operator.py" },
      "reads": ["operator.plan"],
      "writes": [],
      "locks": ["operators_lib"],
      "governance": { "self_modification": true }
    }
  ],

  "programs": [
    {
      "name": "plan_optimize_execute",
      "expr": {
        "seq": [
          "State::Plan",
          "State::Optimize",
          "State::Execute"
        ]
      },
      "confidence": 0.95,
      "cost": 1.0,
      "safety": 0.9
    },
    {
      "name": "choose_repair_or_retry",
      "expr": {
        "choice": [
          {
            "seq": [
              "Control::Repair",
              "State::Optimize"
            ]
          },
          {
            "seq": [
              "Control::Retry",
              "State::Optimize"
            ]
          }
        ]
      },
      "confidence": 0.8,
      "cost": 2.0,
      "safety": 0.85
    },
    {
      "name": "bounded_learn_loop",
      "kind": "cka_pattern",
      "expr": {
        "star": {
          "body": {
            "seq": [
              "State::Validate",
              "State::Memory",
              "State::Learn"
            ]
          },
          "max_unroll": 3
        }
      },
      "confidence": 0.7,
      "cost": 1.0,
      "safety": 0.9
    },
    {
