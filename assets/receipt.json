{
  "rules": [
    {
      "when": { "all": ["always"] },
      "edges": [
        { "from": "Event::ReceiptAttached", "to": "Control::GateReceipt", "weight": 0.97 }
      ]
    },
    {
      "when": { "all": ["accepted", "hash_nonzero"] },
      "edges": [
        { "from": "Control::GateReceipt", "to": "Event::ReceiptAccepted", "weight": "receipt_confidence" },
        { "from": "Event::ReceiptAccepted", "to": "Event::HashNonzero", "weight": "hash_score" },
        { "from": "Event::HashNonzero", "to": "State::Validate", "weight": "validation_score" }
      ]
    },
    {
      "when": { "any": ["not_accepted", "not_hash_nonzero"] },
      "edges": [
        { "from": "Control::GateReceipt", "to": "Event::ReceiptRejected", "weight": "rejection_score" },
        { "from": "Event::ReceiptRejected", "to": "Control::Rollback", "weight": "rollback_score" },
        { "from": "Control::Rollback", "to": "Control::Repair", "weight": "repair_score" }
      ]
    }
  ]
}
