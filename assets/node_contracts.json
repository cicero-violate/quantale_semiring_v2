{
  "contracts": [
    {
      "node": "Control::WriteOperator",
      "requires_payload": ["filename", "source"],
      "allowed_after": ["State::OperatorPlan"],
      "side_effects": ["repo_write", "operator_registry_write"],
      "mutation_mode": "staged",
      "exploration": {
        "allow_direct": false
      }
    },
    {
      "node": "Control::TopologyMutate",
      "side_effects": ["topology_write", "operator_registry_write"],
      "mutation_mode": "staged",
      "exploration": {
        "allow_direct": false
      }
    },
    {
      "node": "Control::PatternMutate",
      "side_effects": ["pattern_write"],
      "mutation_mode": "staged",
      "exploration": {
        "allow_direct": false
      }
    }
  ]
}
